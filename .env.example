# HuggingFace API Token (required for pyannote.audio speaker diarization)
# Get your token from: https://huggingface.co/settings/tokens
# Accept model terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_token_here

# LLM Configuration
# vodtool supports both local (Ollama) and API-based LLMs for topic generation

# Anthropic API (optional, for Claude-based topic generation)
# Required only if using --provider anthropic
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# Local LLM via Ollama (recommended, free, privacy-first)
# No API key required - runs entirely on your machine
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull qwen2.5:3b
# Default provider is "auto" which tries Ollama first, then falls back to Anthropic
