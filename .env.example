# OpenAI API key (required — used for transcription and embeddings)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# Anthropic API key (optional — for Claude-based topic generation)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# Groq API key (optional — alternative transcription provider)
# Free key at console.groq.com
GROQ_API_KEY=your_key_here

# API proxy URL (optional — falls back to direct API keys above)
# Used by the desktop app to route requests through a Cloudflare Worker
# that injects API keys server-side, so end users don't need their own keys.
VITE_API_PROXY_URL=

# Auth token for the API proxy (must match the PROXY_AUTH_TOKEN secret
# configured on the Cloudflare Worker via `wrangler secret put`).
PROXY_AUTH_TOKEN=

# HuggingFace token (legacy — no longer required)
# HF_TOKEN=your_token_here
